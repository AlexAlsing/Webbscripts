{
  "name": "webbscripts",
  "version": "1.0.0",
  "private": true,
  "description": "IT Convenience Scripts portal for Google Apps Script.",
  "scripts": {
    "gas:check": "node scripts/check-clasp-project.js",
    "clasp:login": "clasp login",
    "clasp:create": "clasp create --type standalone --title \"IT Convenience Scripts\" --rootDir .",
    "clasp:clone": "clasp clone",
    "clasp:push": "npm run gas:check && clasp push",
    "clasp:pull": "npm run gas:check && clasp pull",
    "clasp:open": "npm run gas:check && clasp open",
    "clasp:deploy": "npm run gas:check && clasp deploy",
    "clasp:status": "npm run gas:check && clasp status"
  },
  "devDependencies": {
    "@google/clasp": "^2.4.2"
  }
}
