$ErrorActionPreference = 'Stop'

function Write-Section {
  param([string]$Title)
  Write-Output ""
  Write-Output ("=== {0} ===" -f $Title)
}

function Write-Check {
  param(
    [string]$Name,
    [string]$Value
  )
  Write-Output ("[+] {0}: {1}" -f $Name, $Value)
}

function Find-InstalledProgram {
  param([string]$NamePattern)

  $paths = @(
    'HKLM:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\*',
    'HKLM:\SOFTWARE\WOW6432Node\Microsoft\Windows\CurrentVersion\Uninstall\*',
    'HKCU:\SOFTWARE\Microsoft\Windows\CurrentVersion\Uninstall\*'
  )

  foreach ($path in $paths) {
    $match = Get-ItemProperty -Path $path -ErrorAction SilentlyContinue |
      Where-Object { $_.DisplayName -and $_.DisplayName -match $NamePattern } |
      Select-Object -First 1
    if ($match) {
      return $match
    }
  }

  return $null
}

function Get-DefaultAudioByModule {
  $result = @{
    Playback = $null
    Recording = $null
  }

  if (-not (Get-Module -ListAvailable -Name AudioDeviceCmdlets)) {
    return $result
  }

  Import-Module AudioDeviceCmdlets -ErrorAction SilentlyContinue | Out-Null
  if (-not (Get-Command Get-AudioDevice -ErrorAction SilentlyContinue)) {
    return $result
  }

  try {
    $playback = Get-AudioDevice -Playback
    if ($playback -and $playback.Name) {
      $result.Playback = $playback.Name
    }
  } catch {}

  try {
    $recording = Get-AudioDevice -Recording
    if ($recording -and $recording.Name) {
      $result.Recording = $recording.Name
    }
  } catch {}

  return $result
}

function Convert-ChromeMicSettingValue {
  param([object]$Value)

  if ($null -eq $Value) {
    return 'unknown'
  }

  $stringValue = [string]$Value
  if ($stringValue -eq '1') {
    return 'allow'
  }
  if ($stringValue -eq '2') {
    return 'block'
  }
  if ($stringValue -eq '3') {
    return 'ask'
  }
  return ("value={0}" -f $stringValue)
}

function Get-ChromePolicyStatus {
  $status = [ordered]@{
    AudioCaptureAllowed = $null
    AudioCaptureAllowedScope = @()
    AudioCaptureAllowedUrls = @()
    AudioCaptureAllowedUrlsScope = @()
  }

  $policyRoots = @(
    'HKLM:\SOFTWARE\Policies\Google\Chrome',
    'HKCU:\SOFTWARE\Policies\Google\Chrome'
  )

  foreach ($root in $policyRoots) {
    if (-not (Test-Path $root)) {
      continue
    }

    $props = Get-ItemProperty -Path $root -ErrorAction SilentlyContinue
    if ($props -and $null -ne $props.AudioCaptureAllowed) {
      $status.AudioCaptureAllowed = [int]$props.AudioCaptureAllowed
      $status.AudioCaptureAllowedScope += $root
    }

    $urlsKey = Join-Path $root 'AudioCaptureAllowedUrls'
    if (Test-Path $urlsKey) {
      $urlProps = Get-ItemProperty -Path $urlsKey -ErrorAction SilentlyContinue
      if ($urlProps) {
        $entries = $urlProps.PSObject.Properties | Where-Object { $_.Name -notmatch '^PS' } | Sort-Object Name
        foreach ($entry in $entries) {
          if ($entry.Value) {
            $status.AudioCaptureAllowedUrls += [string]$entry.Value
          }
        }
        if ($entries) {
          $status.AudioCaptureAllowedUrlsScope += $urlsKey
        }
      }
    }
  }

  $status.AudioCaptureAllowedScope = $status.AudioCaptureAllowedScope | Select-Object -Unique
  $status.AudioCaptureAllowedUrls = $status.AudioCaptureAllowedUrls | Select-Object -Unique
  $status.AudioCaptureAllowedUrlsScope = $status.AudioCaptureAllowedUrlsScope | Select-Object -Unique
  return [PSCustomObject]$status
}

function Get-ChromePuzzelStatus {
  param([string[]]$TargetDomains)

  $result = [ordered]@{
    ProfilesChecked = 0
    PuzzelMicRules = @()
    PreferredInputs = @()
  }

  $profilesRoot = Join-Path $env:LOCALAPPDATA 'Google\Chrome\User Data'
  if (-not (Test-Path $profilesRoot)) {
    return [PSCustomObject]$result
  }

  $profileDirs = Get-ChildItem -Path $profilesRoot -Directory -ErrorAction SilentlyContinue |
    Where-Object { $_.Name -eq 'Default' -or $_.Name -like 'Profile *' }

  foreach ($profile in $profileDirs) {
    $prefsPath = Join-Path $profile.FullName 'Preferences'
    if (-not (Test-Path $prefsPath)) {
      continue
    }

    $result.ProfilesChecked += 1

    try {
      $json = Get-Content -Raw $prefsPath | ConvertFrom-Json
    } catch {
      continue
    }

    $ranking = $json.media.audio_input.user_preference_ranking
    if ($ranking) {
      $firstChoice = $null
      if ($ranking -is [System.Array]) {
        $firstChoice = [string]$ranking[0]
      } else {
        $firstChoice = [string]$ranking
      }
      $result.PreferredInputs += [PSCustomObject]@{
        Profile = $profile.Name
        FirstChoice = $firstChoice
      }
    }

    $micExceptions = $json.profile.content_settings.exceptions.media_stream_mic
    if (-not $micExceptions) {
      continue
    }

    foreach ($property in $micExceptions.PSObject.Properties) {
      $ruleKey = [string]$property.Name
      foreach ($domain in $TargetDomains) {
        if ($ruleKey -match [regex]::Escape($domain)) {
          $settingValue = $property.Value.setting
          $result.PuzzelMicRules += [PSCustomObject]@{
            Profile = $profile.Name
            RuleKey = $ruleKey
            Setting = Convert-ChromeMicSettingValue -Value $settingValue
          }
          break
        }
      }
    }
  }

  return [PSCustomObject]$result
}

function Ensure-ChildObject {
  param(
    [object]$Parent,
    [string]$PropertyName
  )

  $prop = $Parent.PSObject.Properties[$PropertyName]
  if ($prop -and $null -ne $prop.Value) {
    return $prop.Value
  }

  $child = [PSCustomObject]@{}
  if ($prop) {
    $Parent.$PropertyName = $child
  } else {
    $Parent | Add-Member -NotePropertyName $PropertyName -NotePropertyValue $child
  }
  return $child
}

function Set-NotePropertyValue {
  param(
    [object]$Parent,
    [string]$PropertyName,
    [object]$Value
  )

  $prop = $Parent.PSObject.Properties[$PropertyName]
  if ($prop) {
    $Parent.$PropertyName = $Value
  } else {
    $Parent | Add-Member -NotePropertyName $PropertyName -NotePropertyValue $Value
  }
}

function Get-ChromeTimestampValue {
  $epoch = [DateTime]::Parse('1601-01-01T00:00:00Z').ToUniversalTime()
  $now = (Get-Date).ToUniversalTime()
  return [string][Int64](($now - $epoch).TotalMilliseconds * 1000)
}

function Prompt-YesNo {
  param(
    [string]$Question
  )

  while ($true) {
    $answer = Read-Host ($Question + ' [y/n]')
    if ($null -eq $answer) {
      continue
    }

    $normalized = $answer.Trim().ToLowerInvariant()
    if ($normalized -eq 'y' -or $normalized -eq 'yes') {
      return $true
    }
    if ($normalized -eq 'n' -or $normalized -eq 'no') {
      return $false
    }
  }
}

function Try-SetWindowsDefaultToJabraLink {
  param([string]$LinkPattern)

  $result = [ordered]@{
    Success = $false
    Message = ''
    Playback = $null
    Recording = $null
  }

  if (-not (Get-Module -ListAvailable -Name AudioDeviceCmdlets)) {
    $result.Message = 'AudioDeviceCmdlets is not installed.'
    return [PSCustomObject]$result
  }

  Import-Module AudioDeviceCmdlets -ErrorAction SilentlyContinue | Out-Null
  if (-not (Get-Command Get-AudioDevice -ErrorAction SilentlyContinue) -or -not (Get-Command Set-AudioDevice -ErrorAction SilentlyContinue)) {
    $result.Message = 'AudioDeviceCmdlets commands are unavailable after import.'
    return [PSCustomObject]$result
  }

  try {
    $devices = Get-AudioDevice -List
  } catch {
    $result.Message = 'Failed to enumerate audio devices via AudioDeviceCmdlets.'
    return [PSCustomObject]$result
  }

  $targetPlayback = $devices | Where-Object { $_.Type -eq 'Playback' -and $_.Name -match $LinkPattern } | Select-Object -First 1
  $targetRecording = $devices | Where-Object { $_.Type -eq 'Recording' -and $_.Name -match $LinkPattern } | Select-Object -First 1

  if (-not $targetPlayback -or -not $targetRecording) {
    $result.Message = 'Could not find both playback and recording Jabra Link devices in AudioDeviceCmdlets.'
    return [PSCustomObject]$result
  }

  try {
    $targetPlayback | Set-AudioDevice | Out-Null
    $targetRecording | Set-AudioDevice | Out-Null
    $result.Success = $true
    $result.Playback = $targetPlayback.Name
    $result.Recording = $targetRecording.Name
    $result.Message = 'Windows default playback/recording switched to Jabra Link.'
  } catch {
    $result.Message = 'Set-AudioDevice failed. Open Sound settings and set Jabra Link manually.'
  }

  return [PSCustomObject]$result
}

function Set-ChromePuzzelMicPreferences {
  param(
    [string]$PreferredInputName
  )

  $result = [ordered]@{
    ProfilesUpdated = @()
    ProfilesFailed = @()
    Message = ''
  }

  $profilesRoot = Join-Path $env:LOCALAPPDATA 'Google\Chrome\User Data'
  if (-not (Test-Path $profilesRoot)) {
    $result.Message = 'Chrome profile root was not found.'
    return [PSCustomObject]$result
  }

  $profileDirs = Get-ChildItem -Path $profilesRoot -Directory -ErrorAction SilentlyContinue |
    Where-Object { $_.Name -eq 'Default' -or $_.Name -like 'Profile *' }

  $modifiedCount = 0
  $timestamp = Get-ChromeTimestampValue

  foreach ($profile in $profileDirs) {
    $prefsPath = Join-Path $profile.FullName 'Preferences'
    if (-not (Test-Path $prefsPath)) {
      continue
    }

    try {
      $json = Get-Content -Raw $prefsPath | ConvertFrom-Json

      $profileObj = Ensure-ChildObject -Parent $json -PropertyName 'profile'
      $contentSettingsObj = Ensure-ChildObject -Parent $profileObj -PropertyName 'content_settings'
      $exceptionsObj = Ensure-ChildObject -Parent $contentSettingsObj -PropertyName 'exceptions'
      $micExceptions = Ensure-ChildObject -Parent $exceptionsObj -PropertyName 'media_stream_mic'

      $allowRule = [PSCustomObject]@{
        last_modified = $timestamp
        setting = 1
      }

      Set-NotePropertyValue -Parent $micExceptions -PropertyName 'https://agent.puzzel.com:443,*' -Value $allowRule
      Set-NotePropertyValue -Parent $micExceptions -PropertyName 'https://[*.]puzzel.com:443,*' -Value $allowRule

      if ($PreferredInputName) {
        $mediaObj = Ensure-ChildObject -Parent $json -PropertyName 'media'
        $audioInputObj = Ensure-ChildObject -Parent $mediaObj -PropertyName 'audio_input'
        $audioInputObj.user_preference_ranking = @($PreferredInputName)
      }

      Set-Content -Path $prefsPath -Value ($json | ConvertTo-Json -Depth 50) -Encoding UTF8
      $modifiedCount += 1
      $result.ProfilesUpdated += $profile.Name
    } catch {
      $result.ProfilesFailed += $profile.Name
    }
  }

  $result.Message = ("Updated {0} Chrome profile(s)." -f $modifiedCount)
  return [PSCustomObject]$result
}

Write-Section "Puzzel + Jabra Softphone Check (Windows)"
Write-Output "Timestamp: $(Get-Date -Format 'yyyy-MM-dd HH:mm:ss')"
Write-Output "Computer: $env:COMPUTERNAME"
Write-Output "User: $env:USERNAME"

$modelRegex = '(?i)evolve(?:2|3)? ?75'
$linkRegex = '(?i)jabra link (370|380|390)'
$jabraRegex = '(?i)jabra|evolve|link (370|380|390)'

$allPresent = Get-PnpDevice -PresentOnly -ErrorAction SilentlyContinue
$namedDevices = $allPresent | Where-Object { $_.FriendlyName -or $_.Name } | ForEach-Object {
  [PSCustomObject]@{
    Name = if ($_.FriendlyName) { $_.FriendlyName } else { $_.Name }
    Class = $_.Class
    Status = $_.Status
    InstanceId = $_.InstanceId
  }
}

$jabraDevices = $namedDevices | Where-Object { $_.Name -match $jabraRegex }
$audioEndpoints = Get-PnpDevice -PresentOnly -Class AudioEndpoint -ErrorAction SilentlyContinue |
  Where-Object { $_.FriendlyName -or $_.Name } | ForEach-Object {
    if ($_.FriendlyName) { $_.FriendlyName } else { $_.Name }
  }

$modelHits = $jabraDevices | Where-Object { $_.Name -match $modelRegex }
$bluetoothHits = $jabraDevices | Where-Object {
  $_.Class -eq 'Bluetooth' -or $_.InstanceId -match '^BTH' -or $_.InstanceId -match 'BTHENUM'
}
$dongleHits = $jabraDevices | Where-Object { $_.Name -match $linkRegex }
$standardBluetoothHits = $modelHits | Where-Object {
  $_.Class -eq 'Bluetooth' -or $_.InstanceId -match '^BTH' -or $_.InstanceId -match 'BTHENUM'
}

$connectionType = 'Unknown'
if ($bluetoothHits) {
  $connectionType = 'Bluetooth'
} elseif ($dongleHits) {
  $connectionType = 'USB dongle (Jabra Link)'
} elseif ($modelHits) {
  $connectionType = 'Likely wired/cabled (no Bluetooth or Link dongle detected)'
}

Write-Section "1) Headset model + Bluetooth"
if ($modelHits) {
  Write-Check "Detected Jabra model(s)" (($modelHits | Select-Object -ExpandProperty Name -Unique) -join '; ')
} else {
  Write-Check "Detected Jabra model(s)" "No listed Evolve 75 variant found right now."
}

if ($bluetoothHits) {
  Write-Check "Bluetooth match" (($bluetoothHits | Select-Object -ExpandProperty Name -Unique) -join '; ')
} else {
  Write-Check "Bluetooth match" "No active Jabra Bluetooth endpoint detected."
}

Write-Section "2) Connection type"
Write-Check "Detected connection path" $connectionType
if ($dongleHits) {
  Write-Check "Jabra Link dongle(s)" (($dongleHits | Select-Object -ExpandProperty Name -Unique) -join '; ')
}

Write-Section "3) Jabra Direct installation"
$jabraDirect = Find-InstalledProgram -NamePattern '(?i)^jabra direct'
if ($jabraDirect) {
  $version = if ($jabraDirect.DisplayVersion) { $jabraDirect.DisplayVersion } else { 'unknown version' }
  Write-Check "Jabra Direct" ("Installed ({0})" -f $version)
} else {
  Write-Check "Jabra Direct" "Not installed or not visible in uninstall registry."
}

Write-Section "4) Selected input/output device"
$defaults = Get-DefaultAudioByModule
if ($defaults.Playback -or $defaults.Recording) {
  if ($defaults.Playback) {
    Write-Check "Default output (Playback)" $defaults.Playback
  } else {
    Write-Check "Default output (Playback)" "Not found"
  }

  if ($defaults.Recording) {
    Write-Check "Default input (Recording)" $defaults.Recording
  } else {
    Write-Check "Default input (Recording)" "Not found"
  }
} else {
  Write-Check "Default output/input" "Could not resolve exact defaults natively. Install AudioDeviceCmdlets for exact values."
  Write-Check "Current audio endpoints (detected)" (($audioEndpoints | Select-Object -Unique) -join '; ')
}

Write-Section "5) Built-in laptop mic stuck in Puzzel check"
$builtInMicPattern = '(?i)realtek|internal|built-?in|array|microphone'
$jabraMicPattern = '(?i)jabra|link'

$likelyBuiltInMic = $audioEndpoints | Where-Object { $_ -match $builtInMicPattern }
$likelyJabraMic = $audioEndpoints | Where-Object { $_ -match $jabraMicPattern }

if ($defaults.Recording -and $defaults.Recording -match $builtInMicPattern -and $likelyJabraMic) {
  Write-Check "Warning" "Built-in mic appears to be selected while Jabra endpoint exists. This matches common Puzzel issue."
  Write-Check "Action" "In Windows Sound + Puzzel softphone settings, switch microphone to Jabra Link/Jabra headset."
} else {
  Write-Check "Recording path check" "No clear built-in-mic lock pattern detected."
}

Write-Section "6) Google (Chrome) selected audio device"
$puzzelDomains = @('puzzel.com', 'agent.puzzel.com')
$chromePolicy = Get-ChromePolicyStatus
$chromePuzzel = Get-ChromePuzzelStatus -TargetDomains $puzzelDomains

if ($null -ne $chromePolicy.AudioCaptureAllowed) {
  if ($chromePolicy.AudioCaptureAllowed -eq 1) {
    Write-Check "Chrome policy AudioCaptureAllowed" "Enabled"
  } else {
    Write-Check "Chrome policy AudioCaptureAllowed" ("Value=" + $chromePolicy.AudioCaptureAllowed)
  }
  Write-Check "Policy source" (($chromePolicy.AudioCaptureAllowedScope) -join '; ')
} else {
  Write-Check "Chrome policy AudioCaptureAllowed" "Not configured"
}

if ($chromePolicy.AudioCaptureAllowedUrls -and $chromePolicy.AudioCaptureAllowedUrls.Count -gt 0) {
  Write-Check "AudioCaptureAllowedUrls" (($chromePolicy.AudioCaptureAllowedUrls) -join '; ')
  Write-Check "AllowedUrls source" (($chromePolicy.AudioCaptureAllowedUrlsScope) -join '; ')
  $hasPuzzelPolicy = $false
  foreach ($urlPattern in $chromePolicy.AudioCaptureAllowedUrls) {
    if ($urlPattern -match 'puzzel\.com') {
      $hasPuzzelPolicy = $true
      break
    }
  }
  if ($hasPuzzelPolicy) {
    Write-Check "Puzzel URL policy" "Configured"
  } else {
    Write-Check "Puzzel URL policy" "Missing (recommend adding https://[*.]puzzel.com/ and https://agent.puzzel.com/)"
  }
} else {
  Write-Check "AudioCaptureAllowedUrls" "Not configured"
}

Write-Check "Chrome profiles checked" ([string]$chromePuzzel.ProfilesChecked)
if ($chromePuzzel.PuzzelMicRules -and $chromePuzzel.PuzzelMicRules.Count -gt 0) {
  $rules = $chromePuzzel.PuzzelMicRules | ForEach-Object {
    "{0} => {1} ({2})" -f $_.Profile, $_.RuleKey, $_.Setting
  }
  Write-Check "Puzzel mic rules in Preferences" ($rules -join ' | ')
} else {
  Write-Check "Puzzel mic rules in Preferences" "No explicit puzzel.com mic rule found in local Chrome profiles."
}

if ($chromePuzzel.PreferredInputs -and $chromePuzzel.PreferredInputs.Count -gt 0) {
  $choices = $chromePuzzel.PreferredInputs | ForEach-Object {
    "{0} => {1}" -f $_.Profile, $_.FirstChoice
  }
  Write-Check "Chrome preferred input ranking (first choice)" ($choices -join ' | ')
} else {
  Write-Check "Chrome preferred input ranking" "No readable preferred input ranking found."
}
Write-Check "Note" "Live per-tab selected microphone is still not reliably exposed via standard PowerShell."

Write-Section "7) Guided actions (y/n)"

$preferredJabraInputCandidate = $audioEndpoints |
  Where-Object { $_ -match $linkRegex -and $_ -match '(?i)microphone|mikrofon' } |
  Select-Object -First 1

$preferredJabraOutputCandidate = $audioEndpoints |
  Where-Object { $_ -match $linkRegex -and $_ -match '(?i)speaker|h.gtalare|headphones|h.rlurar' } |
  Select-Object -First 1

if ($standardBluetoothHits -and $standardBluetoothHits.Count -gt 0) {
  $answerRemoveBluetooth = Prompt-YesNo -Question 'Do you want to remove bluetooth connection?'
  if ($answerRemoveBluetooth) {
    $btNames = ($standardBluetoothHits | Select-Object -ExpandProperty Name -Unique) -join '; '
    Write-Check "Bluetooth devices to remove" $btNames
    Write-Check "Action" "Opening Windows Bluetooth settings. Remove the headset pairing manually there."
    try {
      Start-Process 'ms-settings:bluetooth'
    } catch {
      Write-Check "Action" "Could not open Bluetooth settings automatically. Open Settings > Bluetooth & devices."
    }
  } else {
    Write-Check "Bluetooth cleanup" "Skipped by user."
  }
} else {
  Write-Check "Bluetooth cleanup prompt" "No standard Jabra model on Bluetooth detected, prompt skipped."
}

$hasJabraLinkEndpoint = $audioEndpoints | Where-Object { $_ -match $linkRegex }
$defaultOutputNonJabra = $false
$defaultInputNonJabra = $false
if ($defaults.Playback) {
  $defaultOutputNonJabra = $defaults.Playback -notmatch $linkRegex
}
if ($defaults.Recording) {
  $defaultInputNonJabra = $defaults.Recording -notmatch $linkRegex
}

$chromePreferredNonJabra = $false
if ($chromePuzzel.PreferredInputs -and $chromePuzzel.PreferredInputs.Count -gt 0) {
  $nonJabraPreferred = $chromePuzzel.PreferredInputs | Where-Object { $_.FirstChoice -notmatch $linkRegex }
  if ($nonJabraPreferred -and $nonJabraPreferred.Count -gt 0) {
    $chromePreferredNonJabra = $true
  }
}

$otherHeadsetSet = $false
if ($hasJabraLinkEndpoint -and ($defaultOutputNonJabra -or $defaultInputNonJabra -or $chromePreferredNonJabra)) {
  $otherHeadsetSet = $true
}

if ($otherHeadsetSet) {
  $answerSwapWindows = Prompt-YesNo -Question 'Do you want to swap to Jabra link as preferred input/output'
  if ($answerSwapWindows) {
    $swapResult = Try-SetWindowsDefaultToJabraLink -LinkPattern $linkRegex
    if ($swapResult.Success) {
      Write-Check "Windows default switch" $swapResult.Message
      Write-Check "New playback target" $swapResult.Playback
      Write-Check "New recording target" $swapResult.Recording
    } else {
      Write-Check "Windows default switch" $swapResult.Message
      Write-Check "Action" "Opening Sound settings for manual switch to Jabra Link."
      try {
        Start-Process 'ms-settings:sound'
      } catch {
        Write-Check "Action" "Could not open Sound settings automatically."
      }
    }
  } else {
    Write-Check "Windows default switch" "Skipped by user."
  }
} else {
  Write-Check "Swap prompt" "No clear non-Jabra default detected, prompt skipped."
}

$answerPuzzelSite = Prompt-YesNo -Question 'Do you want to set "Jabra link xxx" as prefered input/output on agent.puzzel.com'
if ($answerPuzzelSite) {
  $selectedJabraInput = $preferredJabraInputCandidate
  if (-not $selectedJabraInput -and $defaults.Recording -and $defaults.Recording -match $linkRegex) {
    $selectedJabraInput = $defaults.Recording
  }

  $chromeSet = Set-ChromePuzzelMicPreferences -PreferredInputName $selectedJabraInput
  Write-Check "Chrome update result" $chromeSet.Message
  if ($chromeSet.ProfilesUpdated -and $chromeSet.ProfilesUpdated.Count -gt 0) {
    Write-Check "Profiles updated" (($chromeSet.ProfilesUpdated) -join '; ')
  }
  if ($chromeSet.ProfilesFailed -and $chromeSet.ProfilesFailed.Count -gt 0) {
    Write-Check "Profiles failed" (($chromeSet.ProfilesFailed) -join '; ')
  }
  if ($preferredJabraOutputCandidate) {
    Write-Check "Preferred Jabra output candidate" $preferredJabraOutputCandidate
  }
  Write-Check "Note" "Chrome must be fully restarted after this change. Then verify device selection inside agent.puzzel.com call settings."
} else {
  Write-Check "agent.puzzel.com preference update" "Skipped by user."
}

Write-Section "Done"
Write-Output "Diagnostic completed."
